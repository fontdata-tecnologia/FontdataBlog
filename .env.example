# ─── BANCO DE DADOS ────────────────────────────────────────────────────────
# PostgreSQL próprio (servidor dedicado).
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/fontdatablog
# SSL da conexão ao Postgres:
#   disable      → sem SSL (rede privada — padrão quando esta var está vazia)
#   require      → SSL sem validar a CA (rejectUnauthorized:false)
#   verify-full  → SSL com validação completa da CA
DB_SSL=disable
# Tamanho do pool de conexões (opcional; padrão 10 fora do Supabase).
# DB_POOL_MAX=10

# ─── AUTENTICAÇÃO ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=seu-segredo-jwt-aqui-minimo-32-caracteres

# ─── APLICAÇÃO ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BLOG_NAME=Meu Blog
NODE_ENV=development

# ─── STORAGE (GOOGLE CLOUD STORAGE) ───────────────────────────────────────
# Bucket de uploads de imagem. Os objetos devem ser publicamente legíveis
# (allUsers → Storage Object Viewer).
GCS_BUCKET=fontdatablog-uploads
GCS_PROJECT_ID=meu-projeto-gcp
# Credenciais da service account. Use UMA das opções:
#   (recomendado no Coolify) conteúdo JSON inline da chave da service account:
GCS_CREDENTIALS_JSON=
#   ou o caminho de um arquivo de credenciais montado no container:
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs.json

# ─── IA (OPENROUTER) ─────────────────────────────────────────────────────
# A chave de API do OpenRouter é configurada via painel admin (Configurações → IA).
# Obtenha sua chave em: https://openrouter.ai/keys

# ─── AUTOMAÇÃO (CRON) ──────────────────────────────────────────────────────
# Os endpoints de cron (/api/cron/*) são autorizados via Bearer CRON_SECRET.
# Agende-os nas Scheduled Tasks do Coolify (POST com o header Authorization):
#   /api/cron/data-retention   →  0 3 * * *
#   /api/cron/rss              →  a cada 30 min
#   /api/cron/automation       →  a cada 15 min
#   /api/cron/source-crawlers  →  a cada 15 min
# Gere com: openssl rand -base64 32
CRON_SECRET=

# ─── ANALYTICS / PRIVACIDADE ──────────────────────────────────────────────────
# Salt dedicado para anonimização de IPs em analytics (LGPD Art. 46 §2).
# Gere com: openssl rand -base64 32
# Se não configurado, o sistema faz fallback para JWT_SECRET (retrocompatível).
ANALYTICS_SALT=
